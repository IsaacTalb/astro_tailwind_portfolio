# MyanMyanPay Configuration
# Get these from your MyanMyanPay Dashboard at https://myanmyanpay.com

MMPAY_APP_ID=your_app_id_here
MMPAY_PUBLISHABLE_KEY=pk_test_your_key_here
MMPAY_SECRET_KEY=sk_test_your_key_here
MMPAY_API_URL=https://api.myanmyanpay.com/v1

# Webhook Secret (for verifying webhook signatures)
MMPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Email Configuration (for sending purchase confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Site Configuration
SITE_URL=https://isaac.duckcloud.info

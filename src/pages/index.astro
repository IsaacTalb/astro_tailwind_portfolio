---
import "../styles/global.css";
import MainLayout from '../layouts/MainLayout.astro';
import { HOME, SITE } from '../config';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects'); // Fetch all projects
const blog = await getCollection('blog'); // Fetch all blog posts
const selectedProjects = projects.slice(0, 3); // Get the first 3 projects
const selectedBlogPosts = blog.slice(0, 3); // Get the first 3 blog posts
---

<MainLayout metadata={HOME} image={SITE.Favicon}>
  <section class="py-20 text-center">
    <h1 class="text-4xl font-bold">Hi, I’m Isaac 👋</h1>
    <p class="mt-4 text-lg text-gray-300 max-w-2xl mx-auto">Experienced Full-Stack Developer with 4+ years building web applications, VPS maintenance, and community projects. I build efficient systems with Laravel, React, and modern tooling.</p>
    <div class="mt-8">
      <a class="mr-4 inline-block px-5 py-3 border rounded-lg hover:bg-white hover:text-black" href="/projects">View projects</a>
      <a class="inline-block px-5 py-3 bg-white text-black hover:bg-black hover:text-white hover:border hover:border-white rounded-lg" href="/contact">Contact me</a>
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-semibold">Recent Blog Posts</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      {selectedBlogPosts.map((blog) => (
        <article class="border p-6 rounded card">
          <h3 class="font-semibold">{blog.data.title}</h3>
          <p class="mt-2 text-sm text-gray-400">{blog.data.description}</p>
          <div class="mt-4">
            {blog.data.link && (
              <>
                <a class="text-sm underline hover:text-indigo-200" href={blog.data.link}>Read more</a>
                <span class="mx-2">·</span>
              </>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-semibold">Recent Projects</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      {selectedProjects.map((project) => (
        <article class="border p-6 rounded card">
          <h3 class="font-semibold">{project.data.title}</h3>
          <p class="mt-2 text-sm text-gray-400">{project.data.description}</p>
          <div class="mt-4">
            {project.data.link && (
              <>
                <a class="text-sm" href={project.data.link}>Live Demo</a>
                <span class="mx-2">·</span>
              </>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
  <section class="py-12">
    <h2 class="text-2xl font-semibold">Technology Profile Showcase</h2>
    <div class="mt-6 space-y-8">
      <article class="border p-6 rounded card">
        <h3 class="text-xl font-semibold">Full-Stack Development</h3>
        <p class="mt-3 text-gray-300">You worked extensively with Laravel, Flutter, Next.js, React, Tailwind CSS, MySQL, Supabase, and Firebase.</p>
        <h4 class="mt-4 font-semibold">What you built</h4>
        <ul class="mt-2 list-disc list-inside text-gray-300 space-y-1">
          <li>QR code generator platform with admin CMS</li>
          <li>AI-powered tech news platform</li>
          <li>E-commerce systems and mobile applications</li>
          <li>Business automation tools and learning platforms</li>
          <li>Real-time dashboards and customer inquiry tracking systems</li>
        </ul>
        <p class="mt-4 text-gray-300">You consistently focused on real-world usability, deployment readiness, scalable architecture, automation, and security practices.</p>
      </article>

      <article class="border p-6 rounded card">
        <h3 class="text-xl font-semibold">Mobile App Development</h3>
        <p class="mt-3 text-gray-300">You created and planned several mobile applications using Flutter.</p>
        <h4 class="mt-4 font-semibold">Projects included</h4>
        <ul class="mt-2 list-disc list-inside text-gray-300 space-y-1">
          <li>Couple memo/social app</li>
          <li>Medical herb information app</li>
          <li>News applications</li>
          <li>Firebase-authenticated applications</li>
        </ul>
      </article>

      <article class="border p-6 rounded card">
        <h3 class="text-xl font-semibold">Cloud, DevOps & Infrastructure</h3>
        <p class="mt-3 text-gray-300">You explored and deployed Docker, GitHub Actions, Vercel, Ubuntu, AlmaLinux, Namecheap, VPS infrastructure, and hosting systems.</p>
      </article>

      <article class="border p-6 rounded card">
        <h3 class="text-xl font-semibold">AI, Automation & Product Thinking</h3>
        <p class="mt-3 text-gray-300">You explored OpenAI APIs, Google APIs, NVIDIA APIs, Ollama, OpenClaw, local LLM deployment concepts, and automation systems using Google Apps Script, Sheets, and business integrations.</p>
        <p class="mt-3 text-gray-300">Across projects, you focused on practical systems, deployment, scaling, security, and user-centered product execution for local and regional audiences.</p>
      </article>

      <article class="border p-6 rounded card">
        <h3 class="text-xl font-semibold">Short Professional Summary</h3>
        <p class="mt-3 text-gray-300">Full-stack developer and technology builder experienced in Laravel, Flutter, Next.js, cloud infrastructure, AI integrations, automation systems, and VPS deployment. Built real-world platforms including automation dashboards, educational systems, AI-powered tools, e-commerce platforms, and mobile applications.</p>
      </article>
    </div>
  </section>

</MainLayout>
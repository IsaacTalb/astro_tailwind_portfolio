---
interface Props {
  product: {
    id: string;
    title: string;
    description: string;
    price: number;
    originalPrice?: number;
    image?: string;
    features?: string[];
    isAvailable: boolean;
  };
  type: 'book' | 'course' | 'donation';
}

const { product, type } = Astro.props;

const formatPrice = (price: number) => {
  return new Intl.NumberFormat('my-MM', {
    style: 'currency',
    currency: 'MMK',
    minimumFractionDigits: 0
  }).format(price);
};

const typeLabel = {
  book: '📚 Book',
  course: '🎓 Course',
  donation: '💝 Donation'
};
---

<div class="bg-gray-800 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 group">
  <!-- Image -->
  <div class="relative h-48 overflow-hidden bg-gray-700">
    {product.image ? (
      <img 
        src={product.image} 
        alt={product.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-900 to-purple-900">
        <span class="text-4xl">{type === 'book' ? '📚' : type === 'course' ? '🎓' : '💝'}</span>
      </div>
    )}
    
    <!-- Type Badge -->
    <div class="absolute top-3 left-3">
      <span class="bg-blue-600 text-white text-xs font-semibold px-2 py-1 rounded-full">
        {typeLabel[type]}
      </span>
    </div>
    
    <!-- Sale Badge -->
    {product.originalPrice && (
      <div class="absolute top-3 right-3">
        <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">
          Save {Math.round((1 - product.price/product.originalPrice) * 100)}%
        </span>
      </div>
    )}
  </div>
  
  <!-- Content -->
  <div class="p-5">
    <h3 class="text-lg font-bold text-white mb-2 line-clamp-2">{product.title}</h3>
    <p class="text-gray-400 text-sm mb-4 line-clamp-2">{product.description}</p>
    
    <!-- Features -->
    {product.features && (
      <ul class="space-y-1 mb-4">
        {product.features.slice(0, 3).map((feature) => (
          <li class="flex items-center text-xs text-gray-400">
            <span class="text-green-400 mr-2">✓</span>
            {feature}
          </li>
        ))}
      </ul>
    )}
    
    <!-- Price -->
    <div class="flex items-baseline gap-2 mb-4">
      <span class="text-2xl font-bold text-white">{formatPrice(product.price)}</span>
      {product.originalPrice && (
        <span class="text-sm text-gray-500 line-through">{formatPrice(product.originalPrice)}</span>
      )}
    </div>
    
    <!-- CTA Button -->
    <a 
      href={`/store/checkout?type=${type}&id=${product.id}`}
      class={`w-full py-3 px-4 rounded-lg font-semibold text-center block transition-colors ${
        product.isAvailable 
          ? 'bg-blue-600 hover:bg-blue-700 text-white' 
          : 'bg-gray-600 text-gray-400 cursor-not-allowed'
      }`}
    >
      {product.isAvailable ? (type === 'donation' ? 'Donate Now' : 'Buy Now') : 'Coming Soon'}
    </a>
  </div>
</div>

<style>
    .sticky-nav {
        background-color: transparent;
        transition: background-color 0.5s ease-in-out;
    }

    .sticky-nav a:hover{
        color: rgb(7, 95, 226);
        transition: color 0.5s ease-in-out;
        text-decoration: underline;
    }

    .sticky-nav.scrolled {
        background-color: rgb(255, 255, 255);
        color: black;
    }
</style>

<nav class="container border-b py-6 flex items-center justify-between sticky-nav">
    <a href="/" class="font-semibold">isaactalb</a>
    <div class="space-x-4 text-sm flex items-center">
        <a href="/about">about</a>
        <a href="/projects">projects</a>
        <a href="/blog">blogs</a>
        <a href="/contact">contact</a>
        <div class="ml-4">
          <script type="module" async>
            // Lazy-load ThemeToggle component to avoid SSR mismatch
            (async function(){
              const resp = await fetch('/_astro/theme-toggle.html').catch(()=>null);
              if(!resp || !resp.ok) return;
              const html = await resp.text();
              const wrapper = document.createElement('span');
              wrapper.innerHTML = html;
              document.currentScript.parentNode.appendChild(wrapper);
            })();
          </script>
          <noscript>
            <!-- Fallback theme button -->
            <a href="#" class="px-2 py-1 rounded bg-gray-200 text-sm">Theme</a>
          </noscript>
        </div>
    </div>
</nav>

<script>
    window.addEventListener('scroll', function() {
        const nav = document.querySelector('.sticky-nav');
        if (nav) {
            nav.classList.toggle('scrolled', window.scrollY > 0);
        }
    });
</script>
